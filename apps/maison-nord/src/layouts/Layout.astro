---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Maison Nord - Interior Design Studio",
  description =
    "Maison Nord is a boutique interior design studio crafting Scandinavian-inspired spaces that balance luxury with simplicity.",
  ogImage = "/og-image.svg",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body class="overflow-x-hidden bg-nord-linen text-nord-noir">
    <slot />
  </body>
</html>
