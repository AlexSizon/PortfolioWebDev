---

<div
  id="cursor"
  aria-hidden="true"
  class="pointer-events-none fixed left-0 top-0 z-[9999]"
  style="display:none"
>
  <div
    id="cursor-inner"
    class="rounded-full border border-nord-gold"
    style="width: 22px; height: 22px; transform: translate(-50%, -50%); transition: width 0.2s ease, height 0.2s ease, background-color 0.2s ease, border-color 0.2s ease, opacity 0.2s ease;"
  ></div>
</div>

<style is:global>
  body.cursor-active,
  body.cursor-active a,
  body.cursor-active button,
  body.cursor-active input,
  body.cursor-active textarea {
    cursor: none !important;
  }
</style>

<script>
  const isFinePointer = window.matchMedia("(pointer: fine)").matches;

  if (isFinePointer) {
    const cursor = document.getElementById("cursor");
    const cursorInner = document.getElementById("cursor-inner");

    if (cursor && cursorInner) {
      const cursorEl = cursor as HTMLElement;
      const cursorInnerEl = cursorInner as HTMLElement;

      cursorEl.style.display = "block";
      document.body.classList.add("cursor-active");

      let mouseX = -200;
      let mouseY = -200;
      let curX = -200;
      let curY = -200;

      const setAccentState = (active: boolean) => {
        cursorInnerEl.style.width = active ? "54px" : "22px";
        cursorInnerEl.style.height = active ? "54px" : "22px";
        cursorInnerEl.style.backgroundColor = active
          ? "rgba(196,169,126,0.12)"
          : "transparent";
        cursorInnerEl.style.borderColor = active
          ? "rgba(196,169,126,0.95)"
          : "rgba(196,169,126,0.82)";
      };

      document.addEventListener("mousemove", (event) => {
        mouseX = event.clientX;
        mouseY = event.clientY;
      });

      document.addEventListener("mouseleave", () => {
        cursorInnerEl.style.opacity = "0";
      });

      document.addEventListener("mouseenter", () => {
        cursorInnerEl.style.opacity = "1";
      });

      function animate() {
        curX += (mouseX - curX) * 0.16;
        curY += (mouseY - curY) * 0.16;
        cursorEl.style.left = `${curX}px`;
        cursorEl.style.top = `${curY}px`;
        requestAnimationFrame(animate);
      }

      animate();

      document
        .querySelectorAll<HTMLElement>('[data-cursor="accent"]')
        .forEach((target) => {
          target.addEventListener("mouseenter", () => setAccentState(true));
          target.addEventListener("mouseleave", () => setAccentState(false));
        });
    }
  }
</script>
