---
---

<section
  class="slide relative isolate flex flex-col items-center justify-center overflow-hidden bg-nord-noir"
  aria-label="Introduction"
  data-slide-kind="intro"
  data-slide-label="Intro"
  data-nav-theme="light"
>
  <div
    class="absolute inset-0 opacity-60"
    aria-hidden="true"
    style="background:
      radial-gradient(circle at 20% 20%, rgba(196,169,126,0.16), transparent 34%),
      radial-gradient(circle at 80% 18%, rgba(244,244,244,0.08), transparent 28%),
      linear-gradient(180deg, rgba(244,244,244,0.02), rgba(15,15,15,0));"
  ></div>
  <div
    class="absolute inset-x-8 top-8 h-px bg-gradient-to-r from-transparent via-nord-linen/25 to-transparent md:inset-x-12"
    aria-hidden="true"
  ></div>
  <div
    class="absolute inset-x-8 bottom-8 h-px bg-gradient-to-r from-transparent via-nord-linen/15 to-transparent md:inset-x-12"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-3xl px-8 text-center">
    <p class="mb-10 text-[0.6rem] uppercase tracking-[0.5em] text-nord-linen/35">
      Oslo &middot; Est. 2016
    </p>

    <h1
      class="mb-8 font-display text-5xl font-light italic leading-[1.05] text-nord-linen md:text-7xl xl:text-[6.25rem]"
    >
      Maison Nord
    </h1>

    <p
      class="mb-6 font-display text-lg font-light tracking-[0.22em] text-nord-linen/55 md:text-[1.7rem]"
    >
      Selected Work
    </p>

    <p
      class="mx-auto max-w-[34rem] text-sm leading-relaxed tracking-[0.08em] text-nord-linen/45 md:text-base"
    >
      Quietly luxurious interiors shaped by Nordic light, tactile materials, and
      a studied sense of restraint.
    </p>

    <div class="mt-14 flex flex-col items-center gap-2 text-nord-linen/28">
      <span class="text-[0.62rem] tracking-[0.42em]">SCROLL OR PRESS DOWN</span>
      <svg class="h-4 w-4 animate-pulse" viewBox="0 0 16 16" fill="none">
        <path
          d="M8 3v10M3 8l5 5 5-5"
          stroke="currentColor"
          stroke-width="1"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </div>
  </div>
</section>
