{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd ../.. && pnpm install && pnpm build --filter=okami-ramen"
  },
  "deploy": {
    "startCommand": "node apps/okami-ramen/.next/standalone/apps/okami-ramen/server.js",
    "healthcheckPath": "/menu",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
