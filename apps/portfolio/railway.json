{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd /app && pnpm --filter @repo/portfolio build"
  },
  "deploy": {
    "startCommand": "HOSTNAME=0.0.0.0 node /app/apps/portfolio/.next/standalone/apps/portfolio/server.js",
    "healthcheckPath": "/",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
